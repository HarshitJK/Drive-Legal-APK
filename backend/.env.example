# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

OPENROUTER_API_KEY=sk-or-your_key_here
OPENROUTER_MODEL=mistralai/mixtral-8x7b-instruct

XAI_API_KEY=xai_your_key_here
XAI_MODEL=grok-2-1212

# Leave empty to use Groq/OpenRouter. Set to enable local Ollama.
OLLAMA_BASE_URL=
OLLAMA_MODEL=gemma2:9b

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Get from https://upstash.com — leave empty to use in-memory sessions (dev only)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
SESSION_TTL_SECONDS=86400

# ── WhatsApp ──────────────────────────────────────────────────────────────────
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
META_VERIFY_TOKEN=your_verify_token
META_ACCESS_TOKEN=your_meta_access_token

# ── App ───────────────────────────────────────────────────────────────────────
WIKI_DIR=wiki
MAX_HISTORY_TURNS=6
MAX_WIKI_ARTICLES=3
PARIVAHAN_BASE_URL=https://echallan.parivahan.gov.in
DEBUG=false
RATE_LIMIT_PER_MINUTE=30
