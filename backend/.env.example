# ── LLM providers (set at least one) ─────────────────────────────────────────
# xAI / Grok — https://console.x.ai/
XAI_API_KEY=
XAI_MODEL=grok-3

# OpenRouter — https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Groq — https://console.groq.com/
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Local Ollama (leave blank for cloud mode)
OLLAMA_BASE_URL=
OLLAMA_MODEL=gemma2:9b


# ── Redis / Sessions ──────────────────────────────────────────────────────────
# Upstash Redis — https://upstash.com (leave blank to use in-memory, dev only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
SESSION_TTL_SECONDS=86400


# ── WhatsApp (optional) ───────────────────────────────────────────────────────
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=


# ── App settings ──────────────────────────────────────────────────────────────
WIKI_DIR=wiki
MAX_HISTORY_TURNS=6
MAX_WIKI_ARTICLES=3
PARIVAHAN_BASE_URL=https://echallan.parivahan.gov.in
DEBUG=false
RATE_LIMIT_PER_MINUTE=30
